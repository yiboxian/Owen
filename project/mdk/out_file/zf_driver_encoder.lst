   54          // 函数简介     定时器编码器解码取值
   55          // 参数说明     timer_ch      定时器枚举体
   56          // 返回参数     void
   57          // 备注信息
   58          // 使用示例    encoder_get_count(TIM2_ENCODER)  // 获取定时器2的采集到的编码器数据
   59          //-------------------------------------------------------------------------------------------------------
             -------------
   60          int16 encoder_get_count(encoder_index_enum encoder_n)
   61          {
   62   1          int16 ret = 0;
   63   1          if(encoder_n >= TIM0_ENCODER)
   64   1          {
   65   2              switch(encoder_n)
   66   2              {
   67   3                  case TIM0_ENCODER: ret = (uint16)TH0 << 8; ret |= TL0; break;
   68   3                  case TIM1_ENCODER: ret = (uint16)TH1 << 8; ret |= TL1; break;
   69   3                  case TIM2_ENCODER: ret = (uint16)T2H << 8; ret |= T2L; break;
   70   3                  case TIM3_ENCODER: ret = (uint16)T3H << 8; ret |= T3L; break;
   71   3                  case TIM4_ENCODER: ret = (uint16)T4H << 8; ret |= T4L; break;
   72   3                  case TIM5_ENCODER: ret = (uint16)T5H << 8; ret |= T5L; break;
   73   3                  case TIM6_ENCODER: ret = (uint16)T6H << 8; ret |= T6L; break;
   74   3                  case TIM7_ENCODER: ret = (uint16)T7H << 8; ret |= T7L; break;
   75   3                  case TIM8_ENCODER: ret = (uint16)T8H << 8; ret |= T8L; break;
   76   3                  case TIM9_ENCODER: ret = (uint16)T9H << 8; ret |= T9L; break;
   77   3                  case TIM10_ENCODER: ret = (uint16)T10H << 8; ret |= T10L; break;
   78   3                  case TIM11_ENCODER: ret = (uint16)T11H << 8; ret |= T11L; break;
   79   3                  case TIM17_ENCODER: ret = (uint16)T17H << 8; ret |= T17L; break;
   80   3                  case TIM18_ENCODER: ret = (uint16)T18H << 8; ret |= T18L; break;
   81   3                  default: zf_assert(0); break;            
   82   3              }
   83   2              if(gpio_get_level(encoder_dir_pin[encoder_n & 0x0F + PWMF_ENCODER + 1]) == 0)
   84   2              {
   85   3                  ret = -ret;
   86   3              }
   87   2          }
   88   1          else
   89   1          {
   90   2              ret  = ((*(vuint8 far *)(PWMX_CNTR_ADDR[encoder_n])) << 8);
   91   2              ret |= ((*(vuint8 far *)(PWMX_CNTR_ADDR[encoder_n] + 1)));
   92   2              if(encoder_dir_pin[encoder_n & 0x0F] != 0xFF)
   93   2              {
   94   3                  // 方向编码器
   95   3                  if(gpio_get_level(encoder_dir_pin[encoder_n & 0x0F]) == 0)
   96   3                  {
   97   4                      ret = -ret;
   98   4                  }
   99   3              }
  100   2              else
  101   2              {
  102   3                  // 正交编码器，四倍频模式
  103   3                  ret = ret >> 2;
  104   3              }
  105   2          }
  106   1      
  107   1          return  ret;
  108   1      }
