  202          static void pwm_encoder_dir_init(encoder_index_enum encoder_n, encoder_channel_enum ch1_pin, encoder_chan
             -nel_enum ch2_pin)
  203          {
  204   1      //    encoder_quad_init(encoder_n, ch1_pin, ch2_pin);
  205   1          gpio_init(ch1_pin & 0xFF, GPI, 0, GPI_PULL_UP);
  206   1          gpio_init(ch2_pin & 0xFF, GPI, 0, GPI_PULL_UP);
  207   1          encoder_dir_pin[encoder_n & 0x0F] = (uint8)(ch2_pin & 0xFF);
  208   1          
  209   1          
  210   1          PWMX_CR1(ch1_pin) &= 0xFE;
  211   1          PWMX_PS(ch1_pin)  |= ((ch1_pin >> 8) & 0x03) << (((ch1_pin >> 11) & 0x03) * 2);                             // 选择引脚
  212   1      
  213   1          PWMX_ARRH(ch1_pin) = 0xFF;              // 周期寄存器
  214   1          PWMX_ARRL(ch1_pin) = 0xFF;              // 周期寄存器
  215   1              
  216   1          PWMX_PSCRH(ch1_pin) = 0;                // 分频寄存器
  217   1          PWMX_PSCRL(ch1_pin) = 0;                // 分频寄存器
  218   1      
  219   1          PWMX_SMCR(ch1_pin)  = 0x07 | 5 << 4;    // 外部计数模式 , 滤波后的CH1输入
  220   1      
  221   1          PWMX_CCERX(ch1_pin) = 0x00;             // 关闭所有输出
  222   1          PWMX_CCERX(ch2_pin) = 0x00;             // 关闭所有输出
  223   1          PWMX_CCMRX(ch1_pin) |= 0x01;                // 01:CC1 通道被配置为输入，IC1 映射在TI1 上
  224   1          PWMX_CR1(ch1_pin)   |= 0x01;                // 开启定时器，向上计数
  225   1          
  226   1      }
