  117          void encoder_clear_count(encoder_index_enum encoder_n)
  118          {
  119   1          if(encoder_n >= TIM0_ENCODER)
  120   1          {
  121   2              switch(encoder_n)
  122   2              {
  123   3                  case TIM0_ENCODER:  TR0 = 0; TH0 = 0; TL0 = 0; TR0 = 1; break;
  124   3                  case TIM1_ENCODER:  TR1 = 0; TH1 = 0; TL1 = 0; TR1 = 1; break;
  125   3                  case TIM2_ENCODER:  AUXR    &= ~(1 << 4); T2H = 0;  T2L = 0;  AUXR    |= (1 << 4); break;
  126   3                  case TIM3_ENCODER:  T4T3M   &= ~(1 << 3); T3H = 0;  T3L = 0;  T4T3M   |= (1 << 3); break;
  127   3                  case TIM4_ENCODER:  T4T3M   &= ~(1 << 7); T4H = 0;  T4L = 0;  T4T3M   |= (1 << 7); break;
  128   3                  case TIM5_ENCODER:  T6T5M   &= ~(1 << 3); T5H = 0;  T5L = 0;  T6T5M   |= (1 << 3); break;
  129   3                  case TIM6_ENCODER:  T6T5M   &= ~(1 << 7); T6H = 0;  T6L = 0;  T6T5M   |= (1 << 3); break;
  130   3                  case TIM7_ENCODER:  T8T7M   &= ~(1 << 3); T7H = 0;  T7L = 0;  T8T7M   |= (1 << 3); break;
  131   3                  case TIM8_ENCODER:  T8T7M   &= ~(1 << 7); T8H = 0;  T8L = 0;  T8T7M   |= (1 << 3); break;
  132   3                  case TIM9_ENCODER:  T10T9M  &= ~(1 << 3); T9H = 0;  T9L = 0;  T10T9M  |= (1 << 3); break;
  133   3                  case TIM10_ENCODER: T10T9M  &= ~(1 << 7); T10H = 0; T10L = 0; T10T9M  |= (1 << 3); break;
  134   3                  case TIM11_ENCODER: T11CR   &= ~(1 << 7); T11H = 0; T11L = 0; T11CR   |= (1 << 7); break;
  135   3                  case TIM17_ENCODER: T18T17M &= ~(1 << 3); T17H = 0; T17L = 0; T18T17M |= (1 << 3); break;
  136   3                  case TIM18_ENCODER: T18T17M &= ~(1 << 7); T18H = 0; T18L = 0; T18T17M |= (1 << 7); break;
  137   3                  default: zf_assert(0); break;            
  138   3              }                          
  139   2          }
  140   1          else
  141   1          {
  142   2              // (*(vuint8 far *)(PWMX_CR1_ADDR[encoder_n]))     &= 0xFE;
  143   2              (*(vuint8 far *)(PWMX_CNTR_ADDR[encoder_n]))     = 0;
  144   2              (*(vuint8 far *)(PWMX_CNTR_ADDR[encoder_n] + 1)) = 0;
  145   2              // (*(vuint8 far *)(PWMX_CR1_ADDR[encoder_n]))     |= 0x01;
  146   2          }
  147   1      }
