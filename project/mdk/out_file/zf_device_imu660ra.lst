                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      НЋvalаДШыcmdЖдгІЕФМФДцЦїЕижЗ,ЭЌЪБЗЕЛиstatusзжНк
                       //  @param      cmd         УќСюзж
                       //  @param      val         Д§аДШыМФДцЦїЕФЪ§жЕ
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660ra_simspi_w_reg_byte(uint8 cmd, uint8 val)
                       {
                               cmd |= IMU660RA_SPI_W;
                               imu660ra_simspi_wr_byte(cmd);
                               imu660ra_simspi_wr_byte(val);
                       }
               
               
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      НЋvalаДШыcmdЖдгІЕФМФДцЦїЕижЗ
                       //  @param      cmd         УќСюзж
                       //  @param      val         Д§аДШыМФДцЦїЕФЪ§жЕ
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660ra_simspi_w_reg_bytes(uint8 cmd, uint8 *dat_addr, uint32 len)
                       {
                               cmd |= IMU660RA_SPI_W;
                               imu660ra_simspi_wr_byte(cmd);
                               while(len--)
                               {
                                       imu660ra_simspi_wr_byte(*dat_addr++);
                               }
                       }
               
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      ЖСШЁcmdЫљЖдгІЕФМФДцЦїЕижЗ
