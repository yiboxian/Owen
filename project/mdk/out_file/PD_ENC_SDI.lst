   88          void initSlidingAverage(SlidingAverageFilter* filter, int N) {
   89   1               uint8 Win_i=0;
   90   1          if (N > MAX_WINDOW_SIZE) {
   91   2              N = MAX_WINDOW_SIZE; // 限制窗口大小不能超过最大值
   92   2          }
   93   1      
   94   1          for (Win_i = 0; Win_i < MAX_WINDOW_SIZE; Win_i++) {
   95   2              filter->buffer[Win_i] = 0.0f;
   96   2          }
   97   1          filter->sum = 0.0f;
   98   1          filter->index = 0;
   99   1          filter->count = 0;
  100   1          filter->window_size = N;
  101   1      }
  102          
  103          void slidingAverage(float now_speed, float* avg_speed, SlidingAverageFilter* filter) {
  104   1          // 从和中减去即将被替换的旧值
  105   1          filter->sum -= filter->buffer[filter->index];
  106   1      
  107   1          // 将新的值插入缓冲区
  108   1          filter->buffer[filter->index] = now_speed;
  109   1      
  110   1          // 更新和
  111   1          filter->sum += now_speed;
  112   1      
  113   1          // 更新索引，使其循环回到起始位置
  114   1          filter->index = (filter->index + 1) % filter->window_size;
  115   1      
  116   1          // 如果窗口没有满，增加计数
  117   1          if (filter->count < filter->window_size) {
  118   2              filter->count++;
  119   2          }
  120   1      
  121   1          // 计算并返回当前窗口的平均值
C251 COMPILER V5.60.0,  PD_ENC_SDI                                                         27/03/26  19:28:55  PAGE 3   

  122   1          *avg_speed = filter->sum / filter->count;
  123   1      }


