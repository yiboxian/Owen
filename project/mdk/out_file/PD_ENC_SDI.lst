   90          void initSlidingAverage(SlidingAverageFilter* filter, int N) {
   91   1               uint8 Win_i=0;
   92   1          if (N > MAX_WINDOW_SIZE) {
   93   2              N = MAX_WINDOW_SIZE; // 限制窗口大小不能超过最大值
   94   2          }
   95   1      
   96   1          for (Win_i = 0; Win_i < MAX_WINDOW_SIZE; Win_i++) {
   97   2              filter->buffer[Win_i] = 0.0f;
   98   2          }
   99   1          filter->sum = 0.0f;
  100   1          filter->index = 0;
  101   1          filter->count = 0;
  102   1          filter->window_size = N;
  103   1      }
  104          
  105          void slidingAverage(float now_speed, float* avg_speed, SlidingAverageFilter* filter) {
  106   1          // 从和中减去即将被替换的旧值
  107   1          filter->sum -= filter->buffer[filter->index];
  108   1      
  109   1          // 将新的值插入缓冲区
  110   1          filter->buffer[filter->index] = now_speed;
  111   1      
  112   1          // 更新和
  113   1          filter->sum += now_speed;
  114   1      
  115   1          // 更新索引，使其循环回到起始位置
  116   1          filter->index = (filter->index + 1) % filter->window_size;
  117   1      
  118   1          // 如果窗口没有满，增加计数
  119   1          if (filter->count < filter->window_size) {
  120   2              filter->count++;
  121   2          }
C251 COMPILER V5.60.0,  PD_ENC_SDI                                                         01/04/26  17:07:29  PAGE 3   

  122   1      
  123   1          // 计算并返回当前窗口的平均值
  124   1          *avg_speed = filter->sum / filter->count;
  125   1      }
