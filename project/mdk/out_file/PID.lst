   22                  void place_pid(float error)//方向外环计算pid，函数输入为小车循迹的反馈误差
   23                  {
   24   1                      float A= 0;//低通滤波系数,一般可以为0.9 or 0.8
   25   1                      place_last_out = place_out;//更新上一次值
   26   1                      place_last_error = place_error;//更新上一次值
   27   1                      place_error = error;
   28   1                      place_out = place_kp * place_error + place_kd * (place_error - place_last_error);
   29   1                      //place_out = place_kp * place_error + place_kd * (place_error - place_last_error) + place_gyro_kd * gy
             -ro_z;//最后加上角速度kd 与 滤波后的Z轴角速度 或者 原始值（不推荐，噪音比较大） 的乘积
   30   1                      place_out = place_out * A + place_last_out * (1-A);
   31   1              }
