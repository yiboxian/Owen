   85          void initSlidingAverage(SlidingAverageFilter* filter, int N) {
   86   1               uint8 Win_i=0;
   87   1          if (N > MAX_WINDOW_SIZE) {
   88   2              N = MAX_WINDOW_SIZE; // 限制窗口大小不能超过最大值
   89   2          }
   90   1      
   91   1          for (Win_i = 0; Win_i < MAX_WINDOW_SIZE; Win_i++) {
   92   2              filter->buffer[Win_i] = 0.0f;
   93   2          }
   94   1          filter->sum = 0.0f;
   95   1          filter->index = 0;
   96   1          filter->count = 0;
   97   1          filter->window_size = N;
   98   1      }
   99          
  100          void slidingAverage(float now_speed, float* avg_speed, SlidingAverageFilter* filter) {
  101   1          // 从和中减去即将被替换的旧值
  102   1          filter->sum -= filter->buffer[filter->index];
  103   1      
  104   1          // 将新的值插入缓冲区
  105   1          filter->buffer[filter->index] = now_speed;
  106   1      
  107   1          // 更新和
  108   1          filter->sum += now_speed;
  109   1      
  110   1          // 更新索引，使其循环回到起始位置
  111   1          filter->index = (filter->index + 1) % filter->window_size;
  112   1      
  113   1          // 如果窗口没有满，增加计数
  114   1          if (filter->count < filter->window_size) {
  115   2              filter->count++;
  116   2          }
  117   1      
  118   1          // 计算并返回当前窗口的平均值
  119   1          *avg_speed = filter->sum / filter->count;
  120   1      }

